{
  "$schema": "https://dclawstack.io/schemas/manifest-v1.json",
  "app_id": "doc",
  "name": "DClaw Doc",
  "tagline": "Smart documents",
  "category": "Documents",
  "color": "#6366F1",
  "version": "1.0.0",
  "ports": {
    "backend": 8107,
    "frontend": 3020
  },
  "database": "dclaw_doc",
  "api_base": "/api/v1",
  "health_path": "/health/",
  "features": [
    "documents",
    "workspaces",
    "folders",
    "tags",
    "search"
  ],
  "ai": {
    "copilot_enabled": false,
    "copilot_path": "/api/v1/ai/doc-chat"
  }
}
